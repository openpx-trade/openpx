{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenPX",
  "description": "Open-source, CCXT-style unified SDK for prediction markets.",
  "colors": {
    "primary": "#22C55E",
    "light": "#4ADE80",
    "dark": "#16A34A"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "light": "/images/logo-light.png",
    "dark": "/images/logo-dark.png"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API",
        "groups": [
          {
            "group": "Reference Data",
            "pages": [
              {
                "group": "Markets",
                "pages": [
                  "api/markets/fetch-markets",
                  "api/markets/fetch-market-lineage"
                ]
              }
            ]
          },
          {
            "group": "Market Data",
            "pages": [
              {
                "group": "Orderbook",
                "pages": [
                  "api/orderbook/fetch-orderbook",
                  "api/orderbook/fetch-orderbooks-batch"
                ]
              },
              {
                "group": "Pricing",
                "pages": [
                  "api/pricing/fetch-midpoint",
                  "api/pricing/fetch-midpoints-batch",
                  "api/pricing/fetch-spread",
                  "api/pricing/fetch-last-trade-price",
                  "api/pricing/fetch-open-interest"
                ]
              },
              {
                "group": "Trades",
                "pages": [
                  "api/trades/fetch-trades"
                ]
              }
            ]
          },
          {
            "group": "Trading",
            "pages": [
              {
                "group": "Orders",
                "pages": [
                  "api/orders/create-order",
                  "api/orders/create-orders-batch",
                  "api/orders/cancel-order",
                  "api/orders/cancel-all-orders",
                  "api/orders/fetch-order",
                  "api/orders/fetch-open-orders"
                ]
              }
            ]
          },
          {
            "group": "Account",
            "pages": [
              {
                "group": "Positions",
                "pages": [
                  "api/positions/fetch-positions"
                ]
              },
              {
                "group": "Balance",
                "pages": [
                  "api/balance/fetch-balance",
                  "api/balance/refresh-balance"
                ]
              },
              {
                "group": "Fills",
                "pages": [
                  "api/fills/fetch-fills"
                ]
              }
            ]
          },
          {
            "group": "System",
            "pages": [
              "api/server/fetch-server-time"
            ]
          }
        ]
      },
      {
        "tab": "WebSockets",
        "groups": [
          {
            "group": "Streams",
            "asyncapi": {
              "source": "/openpx.asyncapi.yaml",
              "directory": "websockets"
            }
          }
        ]
      },
      {
        "tab": "Schemas",
        "groups": [
          {
            "group": "Mappings",
            "pages": [
              "schemas/mappings/market",
              "schemas/mappings/event",
              "schemas/mappings/series",
              "schemas/mappings/orderbook"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "Need help?",
        "href": "https://discord.gg/acWpZpVnBj",
        "icon": {
          "name": "discord",
          "library": "fontawesome",
          "style": "brands"
        },
        "align": "end"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "icon": { "name": "github", "library": "fontawesome", "style": "brands" },
        "label": "",
        "href": "https://github.com/openpx-trade/openpx"
      },
      {
        "icon": "desktop",
        "label": "",
        "href": "https://www.openpx.trade"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/openpx-trade/openpx"
    }
  }
}
