{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenPX",
  "description": "Open-source, CCXT-style unified SDK for prediction markets.",
  "colors": {
    "primary": "#22C55E",
    "light": "#4ADE80",
    "dark": "#16A34A"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "light": "/images/logo-light.png",
    "dark": "/images/logo-dark.png"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API",
        "groups": [
          {
            "group": "Markets",
            "pages": [
              "api/markets/fetch-markets",
              "api/markets/fetch-market"
            ]
          },
          {
            "group": "Orderbook",
            "pages": [
              "api/orderbook/fetch-orderbook"
            ]
          },
          {
            "group": "Orders",
            "pages": [
              "api/orders/create-order",
              "api/orders/cancel-order",
              "api/orders/fetch-order",
              "api/orders/fetch-open-orders"
            ]
          },
          {
            "group": "Positions",
            "pages": [
              "api/positions/fetch-positions"
            ]
          },
          {
            "group": "Balance",
            "pages": [
              "api/balance/fetch-balance",
              "api/balance/fetch-balance-raw",
              "api/balance/refresh-balance"
            ]
          },
          {
            "group": "Trades",
            "pages": [
              "api/trades/fetch-trades"
            ]
          },
          {
            "group": "Price History",
            "pages": [
              "api/price-history/fetch-price-history"
            ]
          },
          {
            "group": "Fills",
            "pages": [
              "api/fills/fetch-fills",
              "api/fills/fetch-user-activity"
            ]
          },
          {
            "group": "Orderbook History",
            "pages": [
              "api/orderbook-history/fetch-orderbook-history"
            ]
          }
        ]
      },
      {
        "tab": "WebSockets",
        "groups": [
          {
            "group": "Connection",
            "pages": [
              "websockets/overview",
              "websockets/connecting"
            ]
          },
          {
            "group": "Updates",
            "pages": [
              "websockets/snapshot",
              "websockets/delta",
              "websockets/clear",
              "websockets/trade",
              "websockets/fill"
            ]
          },
          {
            "group": "Session Events",
            "pages": [
              "websockets/session/connected",
              "websockets/session/reconnected",
              "websockets/session/lagged",
              "websockets/session/book-invalidated",
              "websockets/session/error"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/openpx-trade/openpx"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/openpx-trade/openpx"
    }
  }
}
