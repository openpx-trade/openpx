# OpenPX SDK sync pipeline
# Usage: just sync-all

sync-all: python node docs
    @echo "All SDKs and docs synced with Rust core"

schema:
    mkdir -p schema
    cargo run -p px-schema > schema/openpx.schema.json

python-models: schema
    datamodel-codegen \
        --input schema/openpx.schema.json \
        --output px-python/python/openpx/_models.py \
        --output-model-type pydantic_v2.BaseModel \
        --target-python-version 3.9 \
        --use-double-quotes

python-build: python-models
    cd px-python && maturin develop --release

python-stubs: python-build
    @echo "Stubs generated by maturin"

python: python-stubs

node-models: schema
    npx json-schema-to-typescript@15 \
        schema/openpx.schema.json \
        --output px-node/types/models.d.ts

node-build: node-models
    cd px-node && npm run build

node: node-build

docs: schema
    python3 scripts/generate_sdk_docs.py
    @echo "Docs generated in px-documentation/src/"

docs-serve: docs
    cd px-documentation && mdbook serve --open

docs-build: docs
    cd px-documentation && mdbook build

check-sync: schema python-models node-models docs
    git diff --exit-code schema/ px-python/python/openpx/_models.py px-node/types/models.d.ts px-documentation/src/
