        "close_time": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "default": "",
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "liquidity": {
          "format": "double",
          "type": "number"
        },
        "metadata": {
          "default": null
        },
        "outcomes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "prices": {
          "additionalProperties": {
            "format": "double",
            "type": "number"
          },
          "description": "Outcome prices normalized to decimal format (0.0 to 1.0).",
          "type": "object"
        },
        "question": {
          "type": "string"
        },
        "tick_size": {
          "format": "double",
          "type": "number"
        },
        "volume": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "id",
        "liquidity",
        "outcomes",
        "prices",
        "question",
        "tick_size",
        "volume"
      ],
      "title": "Market",
      "type": "object"
    },
