            "string",
            "null"
          ]
        },
        "rules": {
          "description": "Resolution rules",
          "type": [
            "string",
            "null"
          ]
        },
        "settlement_time": {
          "description": "Settlement / resolution time",
          "format": "date-time",
          "type": [
            "string",
