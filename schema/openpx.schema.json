          "type": [
            "number",
            "null"
          ]
        },
        "timestamp": {
          "description": "Period start timestamp (UTC). lightweight-charts expects start-of-period.",
          "format": "date-time",
          "type": "string"
        },
        "volume": {
          "description": "Trade volume in contracts. 0.0 if exchange doesn't provide volume.",
          "format": "double",
          "type": "number"
        }
