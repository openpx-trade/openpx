          "type": [
            "string",
            "null"
          ]
        },
        "spread": {
          "description": "Bid-ask spread (decimal)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "status": {
          "allOf": [
            {
              "$ref": "#/definitions/MarketStatus"
            }
          ],
          "description": "Normalized status: Active, Closed, Resolved"
        },
        "taker_fee_bps": {
          "description": "Taker fee rate (basis points)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "tick_size": {
          "description": "Tick size (minimum price increment, normalized decimal e.g. 0.01)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "title": {
          "description": "Market title",
          "type": "string"
        },
        "token_id_no": {
          "description": "No outcome token ID",
          "type": [
            "string",
            "null"
          ]
        },
        "token_id_yes": {
          "description": "Yes outcome token ID",
          "type": [
            "string",
            "null"
          ]
        },
        "volume": {
          "description": "Total volume (USD)",
          "format": "double",
          "type": "number"
        },
        "volume_1mo": {
          "description": "30-day rolling trading volume (USD)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "volume_1wk": {
          "description": "7-day rolling trading volume (USD)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "volume_24h": {
          "description": "24-hour trading volume (USD)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        }
