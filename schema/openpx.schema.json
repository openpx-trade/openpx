        "accepting_orders": {
          "default": false,
          "description": "Whether the market is currently accepting orders",
          "type": "boolean"
        },
        "best_ask": {
          "description": "Best ask price (normalized 0-1)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "best_bid": {
          "description": "Best bid price (normalized 0-1)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "can_close_early": {
          "description": "Kalshi: can close early",
          "type": [
            "boolean",
            "null"
          ]
        },
        "chain_id": {
          "description": "Chain ID for on-chain markets",
          "type": [
            "string",
            "null"
          ]
        },
        "close_time": {
          "description": "Market close time",
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "condition_id": {
          "description": "Condition ID for CTF",
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "description": "Market creation time",
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "denomination_token": {
          "description": "Denomination token (e.g. USDC address)",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "description": "Full description",
          "type": "string"
        },
        "event_id": {
          "description": "Canonical OpenPX event ID for cross-exchange event grouping.",
          "type": [
            "string",
            "null"
          ]
        },
        "exchange": {
          "description": "Exchange identifier (kalshi, polymarket, opinion)",
          "type": "string"
        },
        "group_id": {
          "description": "Source-native event/group ID from the exchange.",
          "type": [
            "string",
            "null"
          ]
        },
        "icon_url": {
          "description": "Market icon URL",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "Native exchange market ID",
          "type": "string"
        },
        "image_url": {
          "description": "Market image URL",
          "type": [
            "string",
            "null"
          ]
        },
        "last_trade_price": {
          "description": "Last trade price (normalized 0-1)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "liquidity": {
          "description": "Current liquidity",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "maker_fee_bps": {
          "description": "Maker fee rate (basis points)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "market_type": {
          "allOf": [
            {
              "$ref": "#/definitions/MarketType"
            }
          ],
          "description": "Market type classification"
        },
        "min_order_size": {
          "description": "Minimum order size (contracts)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "neg_risk": {
          "description": "Polymarket: neg-risk flag",
          "type": [
            "boolean",
            "null"
          ]
        },
        "neg_risk_market_id": {
          "description": "Polymarket: neg-risk market ID",
          "type": [
            "string",
            "null"
          ]
        },
        "notional_value": {
          "description": "Notional value per contract (Kalshi)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "open_interest": {
          "description": "Current open interest",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "open_time": {
          "description": "Market open time",
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "openpx_id": {
