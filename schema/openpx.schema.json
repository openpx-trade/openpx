    "MarketStatus": {
      "description": "Normalized market status across all exchanges.",
      "enum": [
        "active",
        "closed",
        "resolved"
      ],
      "title": "MarketStatus",
      "type": "string"
    },
    "MarketStatusFilter": {
      "description": "Filter for market status in fetch queries.\n\nUnlike `MarketStatus` (which represents a market's actual status), this enum includes an `All` variant for fetching markets regardless of status.",
      "enum": [
        "active",
        "closed",
        "resolved",
        "all"
      ],
      "type": "string"
    },
    "MarketTrade": {
      "description": "Normalized public market trade, suitable for \"tape\" UIs.\n\n- `price` is normalized to [0.0, 1.0] across all exchanges. - `timestamp` is the exchange-provided trade timestamp (UTC).",
      "properties": {
        "aggressor_side": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "no_price": {
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "outcome": {
          "type": [
            "string",
            "null"
          ]
        },
        "price": {
          "format": "double",
          "type": "number"
        },
        "side": {
          "type": [
            "string",
            "null"
          ]
        },
        "size": {
          "format": "double",
          "type": "number"
        },
        "source_channel": {
          "type": "string"
        },
        "taker_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "format": "date-time",
          "type": "string"
        },
        "tx_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "yes_price": {
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "price",
        "size",
        "source_channel",
        "timestamp"
      ],
      "title": "MarketTrade",
      "type": "object"
    },
    "MarketType": {
      "description": "Market type classification.",
      "enum": [
        "binary",
        "categorical",
        "scalar"
      ],
      "title": "MarketType",
      "type": "string"
    },
    "Order": {
      "properties": {
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "filled": {
          "format": "double",
          "type": "number"
        },
        "id": {
          "type": "string"
        },
        "market_id": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        },
        "price": {
          "format": "double",
          "type": "number"
