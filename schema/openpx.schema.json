          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "price_change_1mo": {
          "description": "30-day YES price change",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "price_change_1wk": {
          "description": "7-day YES price change",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
