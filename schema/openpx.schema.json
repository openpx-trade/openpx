          "type": [
            "string",
            "null"
          ]
        },
        "question": {
          "description": "Market question (may differ from title)",
          "type": [
            "string",
            "null"
          ]
        },
        "question_id": {
          "description": "Question ID (Opinion, Polymarket)",
