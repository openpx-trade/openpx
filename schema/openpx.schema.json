{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ActivityFill": {
      "properties": {
        "asset_id": {
          "type": "string"
        },
        "exchange_ts_ms": {
          "description": "Exchange-authoritative timestamp (millis since epoch).",
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "fee": {
          "description": "Fee charged for this fill. Opinion: `fee` from `trade.record.new`.",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "fill_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "liquidity_role": {
          "anyOf": [
            {
              "$ref": "#/definitions/LiquidityRole"
            },
            {
              "type": "null"
            }
          ]
        },
        "market_id": {
          "type": "string"
        },
        "order_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "outcome": {
          "type": [
            "string",
            "null"
          ]
        },
        "price": {
          "format": "double",
          "type": "number"
        },
        "side": {
          "type": [
            "string",
            "null"
          ]
        },
        "size": {
          "format": "double",
          "type": "number"
        },
        "source_channel": {
          "type": "string"
        },
        "tx_hash": {
          "description": "On-chain transaction hash. Opinion: `txHash` from `trade.record.new`.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "asset_id",
        "market_id",
        "price",
        "size",
        "source_channel"
      ],
      "title": "ActivityFill",
      "type": "object"
    },
    "ActivityTrade": {
      "description": "Activity events still carried inside `WsUpdate::Trade` / `WsUpdate::Fill`. Retained as a typed payload alongside the stream rather than as a separate per-token surface.\n\n`exchange_ts_ms` is exchange-authoritative millis since epoch — uniform with `WsUpdate::{Snapshot, Delta}::exchange_ts`, so every timestamp on the WS surface is the same type (`u64` millis). `chrono::DateTime` was more expressive but cost a representation mismatch at every FFI boundary.",
      "properties": {
        "aggressor_side": {
          "type": [
            "string",
            "null"
          ]
        },
        "asset_id": {
          "type": "string"
        },
        "exchange_ts_ms": {
          "description": "Exchange-authoritative timestamp (millis since epoch).",
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "fee_rate_bps": {
          "description": "Fee rate in basis points (e.g. 0 = no fee, 200 = 2%). Polymarket `last_trade_price` events populate this.",
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "market_id": {
          "type": "string"
        },
        "outcome": {
          "type": [
            "string",
            "null"
          ]
        },
        "price": {
          "format": "double",
          "type": "number"
        },
        "side": {
          "type": [
            "string",
            "null"
          ]
        },
        "size": {
          "format": "double",
          "type": "number"
        },
        "source_channel": {
          "type": "string"
        },
        "trade_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "asset_id",
        "market_id",
        "price",
        "size",
        "source_channel"
      ],
      "title": "ActivityTrade",
      "type": "object"
    },
    "Candlestick": {
      "description": "OHLCV candlestick, normalized across all exchanges. Prices are decimals (0.0 to 1.0). Timestamp is the period START (not end). Serialized over the wire as RFC3339 (DateTime<Utc>) for API consistency.",
      "properties": {
        "close": {
          "format": "double",
          "type": "number"
        },
        "high": {
          "format": "double",
          "type": "number"
        },
        "low": {
          "format": "double",
          "type": "number"
        },
        "open": {
          "format": "double",
          "type": "number"
        },
        "open_interest": {
          "description": "Open interest at this candle's close. Only available from exchanges that report it (e.g., Kalshi).",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "timestamp": {
          "description": "Period start timestamp (UTC). lightweight-charts expects start-of-period.",
          "format": "date-time",
          "type": "string"
        },
        "volume": {
          "description": "Trade volume in contracts. 0.0 if exchange doesn't provide volume.",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "close",
        "high",
        "low",
        "open",
        "timestamp",
        "volume"
      ],
      "title": "Candlestick",
      "type": "object"
    },
    "ExchangeInfo": {
      "properties": {
        "has_approvals": {
          "type": "boolean"
        },
        "has_cancel_order": {
          "type": "boolean"
        },
        "has_create_order": {
          "type": "boolean"
        },
        "has_fetch_balance": {
          "type": "boolean"
        },
        "has_fetch_fills": {
          "type": "boolean"
        },
        "has_fetch_markets": {
          "type": "boolean"
        },
        "has_fetch_orderbook": {
          "type": "boolean"
        },
        "has_fetch_orderbook_history": {
          "type": "boolean"
        },
        "has_fetch_positions": {
          "type": "boolean"
        },
        "has_fetch_price_history": {
          "type": "boolean"
        },
        "has_fetch_trades": {
          "type": "boolean"
        },
        "has_fetch_user_activity": {
          "type": "boolean"
        },
        "has_refresh_balance": {
          "type": "boolean"
        },
        "has_websocket": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "has_approvals",
        "has_cancel_order",
        "has_create_order",
        "has_fetch_balance",
        "has_fetch_fills",
        "has_fetch_markets",
        "has_fetch_orderbook",
        "has_fetch_orderbook_history",
        "has_fetch_positions",
        "has_fetch_price_history",
        "has_fetch_trades",
        "has_fetch_user_activity",
        "has_refresh_balance",
        "has_websocket",
        "id",
        "name"
      ],
      "title": "ExchangeInfo",
      "type": "object"
    },
    "FetchMarketsParams": {
      "properties": {
        "cursor": {
          "default": null,
          "description": "Exchange-specific cursor (offset, page number, or cursor string)",
          "type": [
            "string",
            "null"
          ]
        },
        "event_id": {
          "default": null,
          "description": "Fetch all markets within a specific event. Pass a Kalshi event ticker (e.g., `\"KXBTC-25MAR14\"`), a Polymarket event ID or slug (e.g., `\"903\"` or `\"will-trump-win-2024\"`), or an Opinion market slug (e.g., `\"btc-price-daily\"`) to get its child markets. When set, `series_id`, `cursor`, and `limit` are ignored (not paginated). `status` filtering is still applied client-side.",
          "type": [
            "string",
            "null"
          ]
        },
        "limit": {
          "description": "Per-page limit. Each exchange applies its own server-side cap: Kalshi tops out at 1000, Polymarket at ~500, Opinion is hard-capped at 20. Values above the cap are silently clamped to the cap.",
          "format": "uint",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "series_id": {
          "default": null,
          "description": "Filter by series (Kalshi and Polymarket). Both exchanges organize markets as Series → Events → Markets. Pass a Kalshi series ticker (e.g., `\"KXBTC\"`) or a Polymarket series ID (e.g., `\"10345\"`) to fetch only markets in that series.",
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/definitions/MarketStatusFilter"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Filter by market status. Defaults to Active at the exchange level when None. Use `MarketStatusFilter::All` to fetch markets of any status."
        }
      },
      "title": "FetchMarketsParams",
      "type": "object"
    },
    "FetchOrdersParams": {
      "properties": {
        "market_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "title": "FetchOrdersParams",
      "type": "object"
    },
    "FetchUserActivityParams": {
      "properties": {
        "address": {
          "type": "string"
        },
        "limit": {
          "format": "uint",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "address"
      ],
      "title": "FetchUserActivityParams",
      "type": "object"
    },
    "Fill": {
      "description": "A single fill (trade execution) from a user's order.",
      "properties": {
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "fee": {
          "format": "double",
          "type": "number"
        },
        "fill_id": {
          "type": "string"
        },
        "is_taker": {
          "type": "boolean"
        },
        "market_id": {
          "type": "string"
        },
        "order_id": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        },
        "price": {
          "format": "double",
          "type": "number"
        },
        "side": {
          "$ref": "#/definitions/OrderSide"
        },
        "size": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "created_at",
        "fee",
        "fill_id",
        "is_taker",
        "market_id",
        "order_id",
        "outcome",
        "price",
        "side",
        "size"
      ],
      "title": "Fill",
      "type": "object"
    },
    "InvalidationReason": {
      "description": "Why a specific book was invalidated — handed to users so they can decide whether to alert, log, or handle it silently.",
      "oneOf": [
        {
          "enum": [
            "Reconnect",
            "Lag",
            "ExchangeReset"
          ],
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "SequenceGap": {
              "properties": {
                "expected": {
                  "format": "uint64",
                  "minimum": 0.0,
                  "type": "integer"
                },
                "received": {
                  "format": "uint64",
                  "minimum": 0.0,
                  "type": "integer"
                }
              },
              "required": [
                "expected",
                "received"
              ],
              "type": "object"
            }
          },
          "required": [
            "SequenceGap"
          ],
          "type": "object"
        }
      ]
    },
    "LiquidityRole": {
      "enum": [
        "maker",
        "taker"
      ],
      "type": "string"
    },
    "Market": {
      "description": "Unified prediction market model.\n\nAll exchanges produce this single type directly — no intermediate conversion.\n\n# Price Format\n\nAll prices are normalized to decimal format (0.0 to 1.0). Exchange-specific conversions are handled during parsing:\n\n- **Kalshi**: Fixed-point dollar strings parsed directly (post March 2026 migration). - **Polymarket, Opinion**: Native prices already in decimal (0.0-1.0).",
