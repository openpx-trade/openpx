# OpenPX Configuration
# ====================
# Open-source unified SDK for prediction markets.
# Users bring their own exchange credentials and trade directly.

# Logging
RUST_LOG=info   # (trace, debug, info, warn, error)

# Exchange Credentials
# ====================

# Polymarket (optional - for trading)
# -----------------------------------
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER=0x...
# Signature type: eoa (default, direct wallet), proxy (Magic/email login), gnosis (MetaMask/browser wallet)
POLYMARKET_SIGNATURE_TYPE=eoa
# Builder credentials for affiliate attribution (optional)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Kalshi (optional - uses demo mode if not provided)
# --------------------------------------------------
KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi-private-key.pem

# Limitless (optional - for trading)
# --------------------------------------------------
LIMITLESS_PRIVATE_KEY=0x...

# Opinion (required for Opinion exchange to be available)
# -------------------------------------------------------
OPINION_API_KEY=your-opinion-api-key
OPINION_PRIVATE_KEY=0x...
OPINION_MULTI_SIG_ADDR=0x...

# Predict.fun (optional - uses testnet if not provided)
# -----------------------------------------------------
PREDICTFUN_API_KEY=your-predictfun-api-key
PREDICTFUN_PRIVATE_KEY=0x...
