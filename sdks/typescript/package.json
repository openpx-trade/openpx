{
  "name": "@openpx/sdk",
  "version": "0.1.6",
  "description": "Node.js SDK for OpenPX prediction markets",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "author": "Milind Pathiyal",
  "repository": {
    "type": "git",
    "url": "https://github.com/openpx/openpx"
  },
  "homepage": "https://github.com/openpx/openpx",
  "keywords": [
    "prediction-market",
    "trading",
    "polymarket",
    "kalshi",
    "sdk",
    "napi-rs"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "types/"
  ],
  "scripts": {
    "build": "napi build --release",
    "build:debug": "napi build",
    "prepublishOnly": "napi prepublish -t npm --skip-gh-release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "json-schema-to-typescript": "^15.0.0"
  },
  "napi": {
    "name": "openpx",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  }
}
